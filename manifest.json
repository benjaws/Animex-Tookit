{
  "manifest_version": 3,
  "name": "Animex Toolkit",
  "version": "2.6",
  "description": "Améliore l'interface Animex : Charges, Alertes GM/Sexe, Templates d'emails et Options personnalisables.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "host_permissions": [
    "https://www.animex-ch.blv.admin.ch/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.animex-ch.blv.admin.ch/*"],
      "exclude_matches": [
        "*://*/api/*",
        "*://*/auth/*",
        "*://*/saml*",
        "*://*/*login*",
        "*://*/*error*",
        "*://feds.eiam.admin.ch/*",
        "*://*.eiam.admin.ch/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}